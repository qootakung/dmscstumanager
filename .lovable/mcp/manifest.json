{
  "version": 1,
  "sdk_version": "0.20.0",
  "path": "/mcp",
  "auth": {
    "type": "none"
  },
  "mcp": {
    "server": {
      "name": "ban-don-moon-school-mcp",
      "version": "0.1.0",
      "title": "Ban Don Moon School MCP"
    },
    "tools": [
      {
        "name": "list_students",
        "title": "List students",
        "description": "List students from Ban Don Moon School. Optionally filter by academic year (Buddhist year, e.g. 2568), grade level, or classroom.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "academic_year": {
              "type": "string",
              "description": "Thai Buddhist academic year, e.g. '2568'."
            },
            "grade_level": {
              "type": "string",
              "description": "Grade level, e.g. 'ป.1', 'ป.6'."
            },
            "classroom": {
              "type": "string",
              "description": "Classroom identifier, e.g. '1/1'."
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 500,
              "description": "Max rows to return (default 100)."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "list_teachers",
        "title": "List teachers",
        "description": "List teachers from Ban Don Moon School. Optionally filter by academic year (Thai Buddhist year).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "academic_year": {
              "type": "string",
              "description": "Thai Buddhist academic year, e.g. '2568'."
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 500,
              "description": "Max rows to return (default 100)."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      }
    ]
  }
}
